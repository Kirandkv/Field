# FieldForge Docs — slice 1 configuration
# Nothing below is required to run the vertical slice. All defaults are offline/deterministic.

# SQLite path for the document/chunk store (default: local file, created automatically)
FIELDFORGE_DB_PATH=./fieldforge_docs.sqlite3

# Max upload size in bytes (default: 10 MB)
FIELDFORGE_MAX_UPLOAD_BYTES=10485760

# Number of chunks retrieved per query (default: 5)
FIELDFORGE_RETRIEVAL_K=5

# --- Planned (M2), not read by slice 1 code yet ---
# OPENAI_API_KEY=
# OLLAMA_HOST=http://localhost:11434
# QDRANT_URL=http://localhost:6333
# DATABASE_URL=postgresql://fieldforge:fieldforge@localhost:5432/fieldforge
